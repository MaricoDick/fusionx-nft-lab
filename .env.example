# Public app URL used for metadata and Farcaster manifest
NEXT_PUBLIC_APP_URL=https://your-app-domain.example

# Base Mini App id from base.dev (required for correct attribution)
NEXT_PUBLIC_BASE_APP_ID=REPLACE_WITH_BASE_APP_ID

# WalletConnect project id (required, no fallback)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=REPLACE_WITH_WALLETCONNECT_PROJECT_ID

# Optional custom Base RPC endpoint. Leave blank to use wagmi chain default.
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Optional offchain tracking endpoint. Leave blank to disable offchain tracking.
NEXT_PUBLIC_ATTRIBUTION_TRACK_API=https://your-tracking-domain.example/api/track

# Optional: override deployed FusionX contract address
NEXT_PUBLIC_FUSION_CONTRACT_ADDRESS=0x6287A2bfc3E3de9C19cCe763B738df8C01b902cd

# Optional scan cap for ownerOf/tierOf reads. 0 means scan all token IDs up to nextId-1.
NEXT_PUBLIC_NFT_SCAN_LIMIT=0

# Optional Talent verification value shown as meta tag
NEXT_PUBLIC_TALENT_VERIFICATION=

# Farcaster account association values (only set after signing)
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=
